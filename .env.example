# .env.example
# The password should be replaced with the actual password for the PostgreSQL database.
DATABASE_URL=postgresql://postgres:<password>@db:5432/cosmos_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=cosmos_db
SERVER_PORT=4000
CLIENT_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
